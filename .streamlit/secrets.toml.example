# انسخ هذا الملف إلى secrets.toml واملأ القيم الحقيقية (لا ترفع secrets.toml إلى Git).
# انسخ:  secrets.toml.example  →  secrets.toml

# مفتاح Gemini واحد (Google AI Studio)
# GEMINI_API_KEY = "YOUR_GEMINI_API_KEY_HERE"

# أو عدة مفاتيح JSON كنص
# GEMINI_API_KEYS = '["KEY1","KEY2"]'

# اختياري: OpenRouter / Cohere
# OPENROUTER_API_KEY = ""
# COHERE_API_KEY = ""

# Make.com — روابط الـ Webhook الخاصة بسيناريوهاتك (ليس روابط المشاركة العامة)
# WEBHOOK_UPDATE_PRICES = "https://hook.eu2.make.com/YOUR_UNIQUE_PATH"
# WEBHOOK_MISSING_PRODUCTS = "https://hook.eu2.make.com/YOUR_UNIQUE_PATH"
